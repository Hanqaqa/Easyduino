	)
	(text "USB needs 90 Ohm differential traces. \nAccording to JLCPCB impedance calculator, with a JLC7628 prepreg and 6mil (0.15mm) space between lines\nI have to use 9 mil tracks -> 0.2mm. With a ground layer below\nI have to place vias because of the pinout of USB C. Some other people have placed vias without problems for signal integrity\n"
		(exclude_from_sim no)
		(at 26.035 142.875 0)
		(effects
			(font
				(size 2 2)
			)
			(justify left bottom)
		)
		(uuid "6e6d8f8d-7f8f-45d9-80f2-b8671620539d")
	)
	(text "Input Voltage: 5.5V-9V(External Source through 5V pin) or 5V (USB). ONLY USE ONE VOLTAGE INPUT AT A TIME\nMaximum Output Current at 5V input : 200 mA at 3.3V output\nNo Polarity Protection (External Source)\nOvercurrent Protection: None "
		(exclude_from_sim no)
