		)
		(uuid "c790b209-0bb9-40bf-92e8-8de6062bbcf8")
	)
	(text "Input Voltage: 5V-15V(External Source 5V Pin) 5V (USB) or 3.3V (3.3V Pin). ONLY USE ONE VOLTAGE INPUT AT A TIME\nOutput Current at 3.3V : 1 A (External Source) 500mA (USB)\nNo Polarity Protection (External Source)\nOvercurrent Protection: None "
		(exclude_from_sim no)
